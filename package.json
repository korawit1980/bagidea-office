{
  "name": "bagidea-office",
  "version": "0.8.0",
  "private": true,
  "description": "A living 2.5D AI office that runs as your desktop wallpaper.",
  "type": "commonjs",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "node daemon/server.js",
    "dev:web": "node daemon/server.js",
    "dev:overlay": "node daemon/server.js",
    "dev:world": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev-world.ps1",
    "dev:windowed": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev-windowed.ps1",
    "codex:login": "codex login",
    "codex:login:oauth": "codex login",
    "codex:status": "codex login status",
    "start": "node daemon/server.js",
    "simulate:task": "node daemon/send.js task.started rin",
    "simulate:permission": "node daemon/send.js perm.requested rin"
  }
}
